# Copy to `.env` for local dev overrides.

# Where the Streamlit app will look for the backend.
API_BASE_URL=http://127.0.0.1:8000

# SQLAlchemy URL. SQLite is the default; point this at Postgres in prod.
# DATABASE_URL=sqlite:///./data/expenses.db

# Set to "0" to disable the in-process backend inside Streamlit
# (use when you deploy the API as a separate service).
EMBEDDED_BACKEND=1
